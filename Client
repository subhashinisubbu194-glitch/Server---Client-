import java.io.*;
import java.net.*;

public class Client {

    public static void main(String[] args) {

        try {
            Socket socket = new Socket("localhost", 5000);

            PrintWriter out = new PrintWriter(
                    socket.getOutputStream(), true);

            out.println("Hello Server!");
            out.println("This is CodTech Internship Task 3.");
            out.println("Chat Application Working Successfully.");

            socket.close();

        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}
